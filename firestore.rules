rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // FUNCIONES AUXILIARES
    // =========================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // El usuario es propietario de la tienda si coincide con alguno de los campos
    // de ownership que puede tener el documento /stores/{storeId}:
    //   - ownerId        → campo raíz (documentos legacy)
    //   - userId         → campo raíz (documentos legacy)
    //   - metadata.ownerId → campo canónico actual
    function isStoreOwner(storeId) {
      let storeData = get(/databases/$(database)/documents/stores/$(storeId)).data;
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/stores/$(storeId)) &&
             (
               storeData.ownerId == request.auth.uid ||
               storeData.userId == request.auth.uid ||
               storeData.metadata.ownerId == request.auth.uid
             );
    }

    // Validación de venta pública (schema actual de /sells/{sellId})
    // NOTA: Esta función es defensa en profundidad. En la práctica, las ventas
    // públicas se crean desde el Server Action `createPublicSaleAction` usando
    // el Admin SDK, que bypasea estas reglas. La validación primaria ocurre
    // en el Server Action con Zod (checkoutFormSchema + sell.schema.ts).
    //
    // Como `sells.create` es la única escritura PÚBLICA (sin auth), además de las
    // keys y el storeId se imponen topes de tamaño/tipo (SEC-01) para evitar que
    // un atacante anónimo que golpee Firestore directamente cree documentos
    // gigantes o masivos (resource exhaustion) o contamine el dashboard del
    // comercio. La ruta legítima (Admin SDK) no pasa por aquí, así que estos
    // límites no afectan al checkout real.
    function isValidSellData() {
      return request.resource.data.keys().hasAll([
               'orderNumber', 'storeId', 'source',
               'customer', 'items', 'delivery',
               'payment', 'totals', 'metadata'
             ]) &&
             request.resource.data.storeId is string &&
             request.resource.data.items is list &&
             request.resource.data.items.size() > 0 &&
             request.resource.data.items.size() <= 100 &&
             request.resource.data.totals.total is number &&
             request.resource.data.totals.total >= 0 &&
             request.resource.data.customer.name is string &&
             request.resource.data.customer.name.size() > 0 &&
             request.resource.data.customer.name.size() <= 200;
    }

    function isValidProductData() {
      return request.resource.data.keys().hasAll(['name', 'price', 'storeId']) &&
             request.resource.data.name is string &&
             request.resource.data.name.size() > 0 &&
             request.resource.data.price is number &&
             request.resource.data.price >= 0;
    }

    function isValidCategoryData() {
      return request.resource.data.keys().hasAll(['name', 'storeId']) &&
             request.resource.data.name is string &&
             request.resource.data.name.size() > 0;
    }

    function isValidTagData() {
      return request.resource.data.keys().hasAll(['name', 'storeId']) &&
             request.resource.data.name is string &&
             request.resource.data.name.size() > 0;
    }

    // =========================================================================
    // TIENDAS
    // =========================================================================

    match /stores/{storeId} {
      // Lectura pública (catálogo público)
      allow read: if true;
      // Solo el owner puede modificar la tienda
      allow write: if isStoreOwner(storeId);

      // ── Productos ──────────────────────────────────────────────────────────
      match /products/{productId} {
        // Lectura pública (catálogo sin autenticación)
        allow read: if true;
        allow create: if isStoreOwner(storeId) && isValidProductData();
        allow update: if isStoreOwner(storeId) && isValidProductData();
        allow delete: if isStoreOwner(storeId);
      }

      // ── Categorías ─────────────────────────────────────────────────────────
      match /categories/{categoryId} {
        // Lectura pública (filtros en catálogo)
        allow read: if true;
        allow create: if isStoreOwner(storeId) && isValidCategoryData();
        allow update: if isStoreOwner(storeId) && isValidCategoryData();
        allow delete: if isStoreOwner(storeId);
      }

      // ── Tags ───────────────────────────────────────────────────────────────
      match /tags/{tagId} {
        // Lectura pública (filtros en catálogo)
        allow read: if true;
        allow create: if isStoreOwner(storeId) && isValidTagData();
        allow update: if isStoreOwner(storeId) && isValidTagData();
        allow delete: if isStoreOwner(storeId);
      }

      // ── Ventas ─────────────────────────────────────────────────────────────
      match /sells/{sellId} {
        // Creación pública desde el catálogo (sin autenticación).
        // Se verifica que el storeId del documento coincida con el storeId de la
        // ruta para evitar que un documento creado en la ruta de tienda A
        // apunte al storeId de tienda B.
        allow create: if isValidSellData() &&
                         request.resource.data.storeId == storeId;

        // Solo el owner lee, modifica y elimina ventas del dashboard
        allow read:   if isStoreOwner(storeId);
        allow update: if isStoreOwner(storeId);
        allow delete: if isStoreOwner(storeId);
      }

      // ── Configuraciones ────────────────────────────────────────────────────
      match /settings/{settingId} {
        allow read, write: if isStoreOwner(storeId);
      }

      // ── Notificaciones ─────────────────────────────────────────────────────
      // create/delete solo via Admin SDK (Firebase Functions) — bypasea estas rules.
      match /notifications/{notificationId} {
        allow read, update: if isStoreOwner(storeId);
        allow create, delete: if false;
      }
    }

    // =========================================================================
    // USUARIOS
    // =========================================================================

    match /users/{userId} {
      // Cada usuario solo puede acceder a sus propios datos
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // =========================================================================
    // CATCH-ALL — denegar todo lo no especificado explícitamente
    // =========================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
