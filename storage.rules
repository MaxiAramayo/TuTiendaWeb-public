rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // =========================================================================
    // FUNCIONES AUXILIARES
    // =========================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Imagen válida: content-type image/* y máximo 5 MB
    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size < 5 * 1024 * 1024;
    }

    // El usuario es propietario de la tienda.
    // Verifica los tres campos posibles (idéntico a firestore.rules) para
    // ser consistente con documentos legacy (ownerId / userId) y actuales
    // (metadata.ownerId). Si ninguno de los tres coincide, se deniega el acceso.
    function isStoreOwner(storeId) {
      let storeData = firestore.get(/databases/(default)/documents/stores/$(storeId)).data;
      return isAuthenticated() &&
             firestore.exists(/databases/(default)/documents/stores/$(storeId)) &&
             (
               storeData.ownerId == request.auth.uid ||
               storeData.userId == request.auth.uid ||
               storeData.metadata.ownerId == request.auth.uid
             );
    }

    // =========================================================================
    // IMÁGENES DE TIENDAS (logos, banners, productos, branding, etc.)
    // La regla padre cubre todos los sub-paths — no se necesitan bloques
    // específicos por subcarpeta (/products/, /branding/) ya que comparten
    // exactamente las mismas condiciones.
    // =========================================================================

    match /stores/{storeId}/{allPaths=**} {
      // Lectura pública (catálogo público consume estas URLs directamente)
      allow read: if true;
      // Solo el owner puede subir o actualizar imágenes
      allow write: if isStoreOwner(storeId) && isValidImage();
      // Solo el owner puede eliminar imágenes
      allow delete: if isStoreOwner(storeId);
    }

    // =========================================================================
    // AVATARES DE USUARIO
    // =========================================================================

    match /users/{userId}/avatar/{allPaths=**} {
      allow read, write: if isAuthenticated() &&
                            request.auth.uid == userId &&
                            isValidImage();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // =========================================================================
    // ARCHIVOS TEMPORALES (se eliminan automáticamente a las 24 h)
    // =========================================================================

    match /temp/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() &&
                            request.auth.uid == userId &&
                            isValidImage();
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // =========================================================================
    // CATCH-ALL — denegar cualquier otra ruta no especificada
    // =========================================================================

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
