// ejemplo de .env.local

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# MercadoPago — Public Key (expuesta al browser, sin secretos)
# Obtener en: MP Panel → tu app → Credenciales
NEXT_PUBLIC_MP_PUBLIC_KEY=          # APP_USR-xxxxxxxx (producción)
NEXT_PUBLIC_MP_PUBLIC_KEY_TEST=     # TEST-xxxxxxxx (modo test/sandbox)

# Configuración de Contacto
NEXT_PUBLIC_SUPPORT_NUMBER=

# ── SEO y Medición ──────────────────────────────────────────────────────────

# Google Search Console — token de verificación HTML
# Obtener en: Search Console → Configuración → Verificación del dominio
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Meta Pixel — ID del pixel de conversiones
# Obtener en: Meta Business Manager → Events Manager → Conectar fuentes → Web
NEXT_PUBLIC_META_PIXEL_ID=

# ── Landing Page ─────────────────────────────────────────────────────────────

# URL de la tienda demo (aparece en el botón "Ver demo" de la landing)
# Ejemplo: /carta/mi-tienda-demo
NEXT_PUBLIC_DEMO_STORE_URL=

# URLs de redes sociales (opcional — si no se definen se usan los defaults)
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=

# ── Emuladores de Firebase (desarrollo local) ───────────────────────────────
# Activar SOLO para probar contra los emuladores locales (requiere Java 21+).
# Cliente: conecta auth/firestore/storage a los emuladores.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=
# Admin SDK (server): la presencia de estos hosts enruta al emulador sin credenciales.
FIRESTORE_EMULATOR_HOST=
FIREBASE_AUTH_EMULATOR_HOST=
FIREBASE_STORAGE_EMULATOR_HOST=
# Proyecto demo usado por los emuladores (no necesita ser real)
# Sugerido: demo-tutiendaweb  /  bucket: demo-tutiendaweb.appspot.com
